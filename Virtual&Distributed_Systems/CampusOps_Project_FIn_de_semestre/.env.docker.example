# PostgreSQL
POSTGRES_DB=campusops
POSTGRES_USER=campusops
POSTGRES_PASSWORD=change_me

# Base de donnees Docker
DATABASE_URL=postgresql://campusops:change_me@postgres:5432/campusops

# Securite
SECRET_KEY=replace_with_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development

# URLs
API_BASE_URL=http://backend:8000
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000

# Telegram
TELEGRAM_BOT_TOKEN=

# OpenClaw
OPENCLAW_KEY=replace_with_your_openclaw_shared_key

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT_IMAP=993
MAIL_PORT_SMTP=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_NAME=CampusOps
